# Copy this file to .env and fill in values before deploying.
# For local development, none of these are required — the app falls back
# to SQLite + a dev JWT secret + open CORS automatically.

# --- Security ---
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# --- Database ---
# Leave unset to use local SQLite. Set to a Postgres URL to use Postgres
# (e.g. from Supabase) for data that survives Render restarts/redeploys.
#
# Supabase setup:
#   1. supabase.com → New project (free tier)
#   2. Project Settings → Database → Connection string → URI
#   3. Copy it here. It looks like:
#      postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres
#   4. Use the "Transaction" pooler connection (port 6543), not "Session" (5432) —
#      Render's free tier opens/closes connections per request, and the
#      transaction pooler handles that pattern correctly.
DATABASE_URL=

# --- CORS ---
# Comma-separated list of allowed frontend origins. Leave unset to allow all
# (fine for local dev, NOT recommended once deployed publicly).
CORS_ORIGINS=https://your-app.vercel.app
